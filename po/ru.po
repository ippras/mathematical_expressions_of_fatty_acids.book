#: src/Sum/Nutritional/ProAtherogenic.md:5
#: src/Sum/Nutritional/ProCholesterolemic.md:5
msgid "$$\\ce{C{12:0}} + \\ce{C{14:0}} + \\ce{C{16:0}}$$"
msgstr "$$\\ce{C{12:0}} + \\ce{C{14:0}} + \\ce{C{16:0}}$$"

#: src/Sum/Nutritional/ProAtherogenic.md:7
msgid "\\[!NOTE\\] Weighting factors are not used."
msgstr ""

#: src/Sum/Nutritional/ProAtherogenic.md:12
msgid "Represents the sum of specific saturated fatty acids (lauric, myristic, and palmitic acids) that are known to promote atherogenesis. High dietary intake of these fatty acids encourages the adhesion of lipids to the endothelium and the accumulation of plaque in blood vessels, significantly increasing the risk of cardiovascular diseases."
msgstr ""

#: src/Sum/Nutritional/ProCholesterolemic.md:9
msgid "Sum of hypercholesterolaemic fatty acids"
msgstr "Сумма гиперхолестеринемических жирных кислот"

#: src/Sum/Nutritional/ProCholesterolemic.md:10
msgid "Sum of hypercholesterolemic fatty acids"
msgstr ""

#: src/Sum/Nutritional/ProCholesterolemic.md:14
msgid "Represents the sum of saturated fatty acids that have a strong hypercholesterolemic effect. Consumption of these fatty acids (lauric, myristic, and palmitic acids) is associated with elevated levels of total cholesterol and low-density lipoprotein (LDL) cholesterol in the blood plasma, which can negatively impact cardiovascular health."
msgstr ""

#: src/Sum/Nutritional/ProThrombogenic.md:5
msgid "$$\\ce{C{14:0}} + \\ce{C{16:0}} + \\ce{C{18:0}}$$"
msgstr "$$\\ce{C{14:0}} + \\ce{C{16:0}} + \\ce{C{18:0}}$$"

#: src/Sum/Nutritional/ProThrombogenic.md:9
msgid "Represents the sum of specific saturated fatty acids (myristic, palmitic, and stearic acids) that exhibit prothrombogenic potential. These fatty acids promote the activation of platelets and the formation of blood clots within the cardiovascular system, increasing the risk of thrombosis and related cardiovascular complications."
msgstr ""

